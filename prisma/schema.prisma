generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  password      String
  name          String
  role          Role           @default(FIELD_USER)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  readings      Reading[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model Plant {
  id        String    @id @default(uuid())
  qrCode    String    @unique
  gridName  String
  areaName  String
  latitude  Float  @default(0.0)  // Add @default
  longitude Float  @default(0.0)  // Add @default
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  readings  Reading[]
}

model Reading {
  id          String   @id @default(uuid())
  plantId     String
  height      Float
  girth       Float
  recordedAt  DateTime @default(now())
  recordedBy  String
  plant       Plant    @relation(fields: [plantId], references: [id])
  user        User     @relation(fields: [recordedBy], references: [id])
}

enum Role {
  ADMIN
  SUPERVISOR
  FIELD_USER
}