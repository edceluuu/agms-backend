generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String          @id @default(uuid())
  username    String          @unique
  password    String
  name        String
  role        Role            @default(FIELD_MONITOR)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  readings    GrowthReading[]
  assignments GridAssignment[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model GrowthReading {
  id          String   @id @default(uuid())
  plantId     String
  userId      String
  height      Float
  girth       Float
  weekNumber  Int
  year        Int
  notes       String?
  photoUrl    String?
  capturedAt  DateTime @default(now())
  isUploaded  Boolean  @default(false)
  syncedAt    DateTime?
  isFlagged   Boolean  @default(false)
  flagReason  String?
  user        User     @relation(fields: [userId], references: [id])

  @@unique([plantId, weekNumber, year])
}

model GridAssignment {
  id         String @id @default(uuid())
  userId     String
  gridId     String
  weekNumber Int
  year       Int
  user       User   @relation(fields: [userId], references: [id])

  @@unique([userId, gridId, weekNumber, year])
}

enum Role {
  ADMIN
  SUPERVISOR
  FIELD_MONITOR
}